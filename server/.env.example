# Copy to .env and fill in values. For Render, add these as Environment Variables.

# --- Google Sheets (New User Logging) ---
# SPREADSHEET_ID: From URL https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
SPREADSHEET_ID=
# From Service Account JSON (client_email)
GOOGLE_SHEETS_CLIENT_EMAIL=
# Full private_key; in Render use literal \n for newlines, e.g.:
# "-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEETS_PRIVATE_KEY=

# --- Gmail (Welcome Email) ---
# VERCEL_CLIENT_ID / VERCEL_CLIENT_SECRET are used as Google OAuth (same credentials)
# From OAuth flow: refresh_token, access_token
