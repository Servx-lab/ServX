{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@servx/errors": ["../../packages/errors/index.ts"],
      "@servx/crypto": ["../../packages/crypto/index.ts"],
      "@servx/config": ["../../packages/config/index.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
